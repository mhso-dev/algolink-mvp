{
  "$schema": "https://design-tokens.org/community-spec.json",
  "name": "algolink-design-tokens",
  "version": "0.1.0",
  "description": "Algolink AI Agentic 업무 지원 시스템 디자인 토큰 — visual-identity.md / system.md 단일 진실 소스",
  "color": {
    "primary": {
      "DEFAULT": "#2563EB",
      "hover": "#1D4ED8",
      "active": "#1E40AF",
      "foreground": "#FFFFFF",
      "muted": "#DBEAFE",
      "muted-foreground": "#1E3A8A"
    },
    "secondary": {
      "DEFAULT": "#0F172A",
      "hover": "#1E293B",
      "foreground": "#F8FAFC",
      "muted": "#F1F5F9",
      "muted-foreground": "#475569"
    },
    "accent": {
      "DEFAULT": "#F59E0B",
      "hover": "#D97706",
      "foreground": "#1E293B",
      "muted": "#FEF3C7"
    },
    "neutral": {
      "50":  "#FAFAFA",
      "100": "#F4F4F5",
      "200": "#E4E4E7",
      "300": "#D4D4D8",
      "400": "#A1A1AA",
      "500": "#71717A",
      "600": "#52525B",
      "700": "#3F3F46",
      "800": "#27272A",
      "900": "#18181B",
      "950": "#09090B"
    },
    "background": "#FAFAFA",
    "surface": "#FFFFFF",
    "border": "#E4E4E7",
    "border-strong": "#D4D4D8",
    "text": {
      "DEFAULT": "#18181B",
      "muted": "#71717A",
      "subtle": "#A1A1AA",
      "inverse": "#FAFAFA"
    },
    "state": {
      "request":     { "DEFAULT": "#94A3B8", "muted": "#F1F5F9", "label": "의뢰" },
      "proposed":    { "DEFAULT": "#60A5FA", "muted": "#DBEAFE", "label": "강사제안" },
      "confirmed":   { "DEFAULT": "#3B82F6", "muted": "#BFDBFE", "label": "배정확정" },
      "in-progress": { "DEFAULT": "#10B981", "muted": "#D1FAE5", "label": "교육중" },
      "completed":   { "DEFAULT": "#6B7280", "muted": "#E5E7EB", "label": "교육종료" },
      "settled":     { "DEFAULT": "#22C55E", "muted": "#DCFCE7", "label": "정산완료" },
      "pending":     { "DEFAULT": "#F59E0B", "muted": "#FEF3C7", "label": "대기" },
      "alert":       { "DEFAULT": "#EF4444", "muted": "#FEE2E2", "label": "이슈" },
      "info":        { "DEFAULT": "#06B6D4", "muted": "#CFFAFE", "label": "정보" }
    },
    "dark": {
      "background": "#09090B",
      "surface": "#18181B",
      "border": "#27272A",
      "border-strong": "#3F3F46",
      "text": {
        "DEFAULT": "#FAFAFA",
        "muted": "#A1A1AA",
        "subtle": "#71717A"
      }
    }
  },
  "typography": {
    "font-family": {
      "sans": "'Pretendard Variable', Pretendard, -apple-system, BlinkMacSystemFont, 'system-ui', Roboto, 'Helvetica Neue', 'Segoe UI', 'Apple SD Gothic Neo', 'Noto Sans KR', 'Malgun Gothic', sans-serif",
      "mono": "'JetBrains Mono', 'SF Mono', Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace"
    },
    "font-size": {
      "display": { "size": "32px", "line": "1.2", "weight": "700" },
      "h1":      { "size": "24px", "line": "1.3", "weight": "700" },
      "h2":      { "size": "20px", "line": "1.4", "weight": "600" },
      "h3":      { "size": "16px", "line": "1.5", "weight": "600" },
      "body":    { "size": "14px", "line": "1.5", "weight": "400" },
      "body-strong": { "size": "14px", "line": "1.5", "weight": "600" },
      "caption": { "size": "12px", "line": "1.4", "weight": "400" },
      "mono":    { "size": "13px", "line": "1.4", "weight": "400", "family": "mono" }
    }
  },
  "spacing": {
    "0": "0px", "1": "4px", "2": "8px", "3": "12px", "4": "16px", "5": "20px",
    "6": "24px", "8": "32px", "10": "40px", "12": "48px", "16": "64px", "20": "80px"
  },
  "radius": {
    "none": "0px",
    "sm": "4px",
    "md": "6px",
    "lg": "8px",
    "xl": "12px",
    "2xl": "16px",
    "full": "9999px"
  },
  "shadow": {
    "sm": "0 1px 2px 0 rgba(0,0,0,0.05)",
    "md": "0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -2px rgba(0,0,0,0.05)",
    "lg": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -4px rgba(0,0,0,0.05)",
    "xl": "0 20px 25px -5px rgba(0,0,0,0.10), 0 8px 10px -6px rgba(0,0,0,0.06)",
    "focus": "0 0 0 2px #FFFFFF, 0 0 0 4px #2563EB"
  },
  "motion": {
    "duration": {
      "fast": "100ms",
      "default": "150ms",
      "slow": "200ms"
    },
    "easing": {
      "standard": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)"
    }
  },
  "layout": {
    "sidebar-width": "240px",
    "sidebar-width-collapsed": "64px",
    "topbar-height": "56px",
    "max-width-app": "1440px",
    "max-width-content": "1200px",
    "max-width-form": "480px",
    "table-row-height": "44px",
    "table-row-height-dense": "36px"
  },
  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "z-index": {
    "base": "0",
    "sticky": "10",
    "dropdown": "20",
    "popover": "30",
    "tooltip": "40",
    "modal": "50",
    "toast": "60"
  }
}
