# Algolink — Environment Variables Template
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# ===========================================
# Database (Supabase / Postgres 16)
# ===========================================
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ===========================================
# Supabase (SPEC-AUTH-001)
# ===========================================
# Public Supabase project URL — exposed to browser.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Publishable (anon) API key — Supabase 2024+ 명칭.
# 기존 ANON_KEY와 동일 의미. 브라우저에 노출 가능 (RLS로 보호).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace-with-publishable-key

# Service role key — 서버 전용. 절대 NEXT_PUBLIC_ prefix 사용 금지.
# src/auth/admin.ts (import 'server-only') 에서만 참조.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# 앱 base URL — 비밀번호 재설정/초대 콜백 redirect_to 구성용.
# 로컬: http://localhost:3000 / 프로덕션: https://algolink.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# PII Encryption (pgcrypto symmetric key)
# 32+ bytes recommended. Used by app.encrypt_pii / app.decrypt_pii.
# Application MUST set this on every connection via:
#   SET LOCAL app.pii_encryption_key = '...';
# ===========================================
PII_ENCRYPTION_KEY=replace-with-32byte-random-secret

# ===========================================
# Anthropic Claude API (SPEC-INSTRUCTOR-001)
# ===========================================
# AI 만족도 요약 — 누락 시 폴백 카드 + 평균 점수 표시.
# 서버 전용. 절대 NEXT_PUBLIC_ prefix 사용 금지.
ANTHROPIC_API_KEY=replace-with-anthropic-api-key
